# Copy to `.env` (gitignored) and fill in real values for local/prod runs.

# intent-processor: RabbitMQ connection string (amqp://user:pass@host:port/vhost)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/%2f

# intent-processor: address the HTTP/Socket.IO server binds to
INTENT_PROCESSOR_BIND=0.0.0.0:3000
